@model IEnumerable<EmployeeLab.Models.Employee>

@{
    ViewData["Title"] = "Сотрудники";
}

<h1>Управление сотрудниками</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (ViewBag.Filter != null)
{
    <h4 class="text-info">@ViewBag.Filter</h4>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить сотрудника</a>
    <a asp-action="Active" class="btn btn-success">Активные</a>
    <a asp-action="Index" class="btn btn-secondary">Все сотрудники</a>
</p>

<div class="row mb-3">
    <div class="col-md-4">
        <div class="dropdown">
            <button class="btn btn-outline-info dropdown-toggle" type="button" data-bs-toggle="dropdown">
                Фильтр по отделу
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" asp-action="ByDepartment" asp-route-department="IT">IT</a></li>
                <li><a class="dropdown-item" asp-action="ByDepartment" asp-route-department="Управление">Управление</a></li>
                <li><a class="dropdown-item" asp-action="ByDepartment" asp-route-department="HR">HR</a></li>
            </ul>
        </div>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Id)</th>
            <th>@Html.DisplayNameFor(model => model.FullName)</th>
            <th>@Html.DisplayNameFor(model => model.Position)</th>
            <th>@Html.DisplayNameFor(model => model.Department)</th>
            <th>@Html.DisplayNameFor(model => model.Salary)</th>
            <th>@Html.DisplayNameFor(model => model.HireDate)</th>
            <th>@Html.DisplayNameFor(model => model.IsActive)</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.IsActive ? "" : "table-secondary")">
                <td>@item.Id</td>
                <td>@item.FullName</td>
                <td>@item.Position</td>
                <td>@item.Department</td>
                <td>@item.Salary.ToString("C")</td>
                <td>@item.HireDate.ToString("dd.MM.yyyy")</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Активен</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Неактивен</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>